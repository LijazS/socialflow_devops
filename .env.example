# ─────────────────────────────────────────────────────────
#  SocialFlow — Environment Variables
#  Copy this to .env and fill in your values:
#    cp .env.example .env
# ─────────────────────────────────────────────────────────

# ── MySQL (local Docker) ───────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=sfuser
MYSQL_PASSWORD=sfpassword

# ── JWT ───────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
JWT_SECRET=supersecretkey_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Frontend service URLs ──────────────────────────────
# Local Docker Compose (default):
VITE_AUTH_URL=http://localhost:8001
VITE_POST_URL=http://localhost:8002
VITE_FEED_URL=http://localhost:8003
VITE_NOTIF_URL=http://localhost:8004
VITE_NOTIF_WS_URL=ws://localhost:8004

# AWS EC2 example (replace with your EC2 public IP/domain):
# VITE_AUTH_URL=http://<EC2_PUBLIC_IP>:8001
# VITE_POST_URL=http://<EC2_PUBLIC_IP>:8002
# VITE_FEED_URL=http://<EC2_PUBLIC_IP>:8003
# VITE_NOTIF_URL=http://<EC2_PUBLIC_IP>:8004
# VITE_NOTIF_WS_URL=ws://<EC2_PUBLIC_IP>:8004

# ── AWS RDS (remove the mysql service from docker-compose) ──
# Replace each service's DATABASE_URL with:
# mysql+pymysql://<DB_USER>:<DB_PASS>@<RDS_ENDPOINT>:3306/<DB_NAME>
